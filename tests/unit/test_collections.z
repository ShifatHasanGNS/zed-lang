-- test_collections.z
-- Covers: fixed arrays (aggregate init, const-expr sizes, zero-init, len, mutation),
--         slices (exclusive, inclusive, full, mutation via slice),
--         dynamic arrays (append, len, cap, reserve, clear, index read/write),
--         array of structs, soft keywords as variable names

cimport "stdio.h"

-- ── Const-expr array sizes ───────────────────────────────────────────────────

ROWS  :: 4
COLS  :: 4
SIZE  :: ROWS * COLS              -- 16
PAD   :: (ROWS + 2) * (COLS + 2) -- 36

#assert SIZE == 16
#assert PAD  == 36

-- ── Struct used in collection tests ─────────────────────────────────────────

Point :: struct {
    x: i32,
    y: i32,
}

-- Struct with a const-expr sized array field (tests symtable sub-pass B0 fix)
SNAKE_MAX :: 4
Snake :: struct {
    size:  i32,
    cells: [SNAKE_MAX]Point,
}

-- ── Fixed arrays ─────────────────────────────────────────────────────────────

check_fixed_arrays :: proc() -> bool {
    -- Zero-init by default
    nums: [4]i32
    if nums[0] != 0 { return false }
    if nums[3] != 0 { return false }

    -- Element assign and read
    nums[0] = 10
    nums[1] = 20
    nums[2] = 30
    nums[3] = 40
    if nums[0] != 10 { return false }
    if nums[2] != 30 { return false }

    -- len on fixed array
    if len(nums) != 4 { return false }

    -- Aggregate initializer
    evens: [5]i32 = { 2, 4, 6, 8, 10 }
    if evens[0] != 2  { return false }
    if evens[4] != 10 { return false }
    if len(evens) != 5 { return false }

    -- Const-expr size: SIZE = 16
    grid: [SIZE]i32
    for i in 0 ..< SIZE {
        grid[i] = i * 2
    }
    if grid[0]  != 0  { return false }
    if grid[15] != 30 { return false }
    if len(grid) != 16 { return false }

    -- Const-expr size: PAD = 36
    pad_arr: [PAD]i32
    pad_arr[0]  = 1
    pad_arr[35] = 99
    if len(pad_arr) != 36 { return false }
    if pad_arr[35]  != 99 { return false }

    -- Pointer into array
    p := &nums[1]
    if p.* != 20 { return false }
    p.* = 99
    if nums[1] != 99 { return false }

    return true
}

-- ── Array of structs ─────────────────────────────────────────────────────────

check_array_of_structs :: proc() -> bool {
    -- Zero-init
    pts: [3]Point
    if pts[0].x != 0 { return false }
    if pts[2].y != 0 { return false }

    -- Assign fields
    pts[0].x = 1
    pts[0].y = 2
    pts[1].x = 3
    pts[1].y = 4
    if pts[0].x != 1 { return false }
    if pts[1].y != 4 { return false }

    -- Aggregate initializer
    verts: [2]Point = { Point{x=10,y=20}, Point{x=30,y=40} }
    if verts[0].x != 10 { return false }
    if verts[1].y != 40 { return false }

    -- Pointer to struct inside array
    pp := &verts[1]
    pp.*.x = 99
    if verts[1].x != 99 { return false }

    return true
}

-- ── Struct with const-expr array field ───────────────────────────────────────

check_struct_array_field :: proc() -> bool {
    s: Snake
    if s.size    != 0 { return false }
    if s.cells[0].x != 0 { return false }

    s.size = 2
    s.cells[0].x = 5
    s.cells[0].y = 7
    s.cells[1].x = 8
    s.cells[1].y = 2
    if s.cells[0].x != 5 { return false }
    if s.cells[1].y != 2 { return false }
    if s.size != 2 { return false }

    return true
}

-- ── Slices ───────────────────────────────────────────────────────────────────

check_slices :: proc() -> bool {
    arr: [8]i32
    for i in 0 ..< 8 {
        arr[i] = i * 10
    }
    -- arr = [0, 10, 20, 30, 40, 50, 60, 70]

    -- Exclusive slice [2, 5)  →  elements at indices 2,3,4
    s := arr[2 ..< 5]
    if len(s) != 3  { return false }
    if s[0]   != 20 { return false }
    if s[1]   != 30 { return false }
    if s[2]   != 40 { return false }

    -- Inclusive slice [3, 6]  →  elements at indices 3,4,5,6
    s2 := arr[3 ..= 6]
    if len(s2) != 4  { return false }
    if s2[0]   != 30 { return false }
    if s2[3]   != 60 { return false }

    -- Full slice
    full := arr[:]
    if len(full) != 8  { return false }
    if full[0]   != 0  { return false }
    if full[7]   != 70 { return false }

    -- Mutation via slice — writes back to original array
    s[0] = 999
    if arr[2] != 999 { return false }

    -- Slice of non-zero offset
    tail := arr[5 ..< 8]
    if len(tail) != 3  { return false }
    if tail[0]   != 50 { return false }

    return true
}

-- ── Dynamic arrays ───────────────────────────────────────────────────────────

check_dynamic_arrays :: proc() -> bool {
    nums: [dynamic]i32

    -- Empty state
    if len(nums) != 0 { return false }
    if cap(nums) != 0 { return false }

    -- reserve: len stays 0, cap grows, slots are zero
    reserve(&nums, 10)
    if len(nums) != 0   { return false }
    if cap(nums) < 10   { return false }
    if nums[0]   != 0   { return false }  -- reserved slot reads zero

    -- append
    append(&nums, 1)
    append(&nums, 2)
    append(&nums, 3)
    if len(nums) != 3 { return false }
    if nums[0]   != 1 { return false }
    if nums[1]   != 2 { return false }
    if nums[2]   != 3 { return false }

    -- mutate via index
    nums[1] = 99
    if nums[1] != 99 { return false }

    -- append many to exercise reallocation
    for i in 0 ..< 20 {
        append(&nums, i)
    }
    if len(nums) != 23 { return false }
    if nums[3]   != 0  { return false }   -- first of the loop-appended elements
    if nums[22]  != 19 { return false }   -- last appended

    -- clear: len drops to 0, allocation retained
    prev_cap := cap(nums)
    clear(&nums)
    if len(nums) != 0        { return false }
    if cap(nums) < prev_cap  { return false }   -- capacity preserved

    -- reuse after clear
    append(&nums, 42)
    if len(nums) != 1  { return false }
    if nums[0]   != 42 { return false }

    return true
}

-- ── reserve zero-init ─────────────────────────────────────────────────────────

check_reserve_zeroinit :: proc() -> bool {
    buf: [dynamic]i32
    reserve(&buf, 5)
    if len(buf) != 0 { return false }
    if cap(buf) < 5  { return false }

    -- All reserved slots read as zero
    for i in 0 ..< 5 {
        if buf[i] != 0 { return false }
    }

    -- Writing directly into reserved slots
    buf[0] = 10
    buf[4] = 50
    if buf[0] != 10 { return false }
    if buf[4] != 50 { return false }

    -- len still 0 after direct index writes
    if len(buf) != 0 { return false }

    return true
}

-- ── Soft keywords as variable names ──────────────────────────────────────────

check_soft_keywords :: proc() -> bool {
    arr: [dynamic]i32
    append(&arr, 5)
    append(&arr, 6)

    len := len(arr)     -- 'len' used as both builtin and variable name
    cap := cap(arr)
    if len != 2  { clear(&arr) return false }
    if cap < 2   { clear(&arr) return false }

    -- append, reserve, clear as variable names
    reserve := 99
    append  := 100
    if reserve != 99  { return false }
    if append  != 100 { return false }

    clear(&arr)
    return true
}

-- ── main ─────────────────────────────────────────────────────────────────────

main :: proc() -> i32 {
    if not check_fixed_arrays()       { printf("FAIL fixed_arrays\n")       return 1 }
    if not check_array_of_structs()   { printf("FAIL array_of_structs\n")   return 1 }
    if not check_struct_array_field() { printf("FAIL struct_array_field\n") return 1 }
    if not check_slices()             { printf("FAIL slices\n")             return 1 }
    if not check_dynamic_arrays()     { printf("FAIL dynamic_arrays\n")     return 1 }
    if not check_reserve_zeroinit()   { printf("FAIL reserve_zeroinit\n")   return 1 }
    if not check_soft_keywords()      { printf("FAIL soft_keywords\n")      return 1 }

    printf("test_collections: OK\n\n\n")
    return 0
}
