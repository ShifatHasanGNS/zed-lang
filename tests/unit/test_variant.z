-- test_variant.z
-- Covers tagged unions (variant keyword):
--   declaration, construction, match with binding, match without binding,
--   nested payloads, default case

cimport "stdio.h"
cimport "string.h"

-- ── Basic tagged union ────────────────────────────────────────────────────

CircleData :: struct { radius: f32 }
RectData   :: struct { width: f32, height: f32 }

Shape :: variant {
    Circle: CircleData,
    Rect:   RectData,
}

area :: proc(s: Shape) -> f32 {
    match s {
        case .Circle(c) { return 3.14159 * c.radius * c.radius }
        case .Rect(r)   { return r.width * r.height }
    }
    return 0.0
}

check_basic :: proc() -> bool {
    circle := Shape{ tag = Shape_Tag.Circle, data = Shape_Data{ Circle = CircleData{ radius = 2.0 } } }
    rect   := Shape{ tag = Shape_Tag.Rect,   data = Shape_Data{ Rect   = RectData{ width = 3.0, height = 4.0 } } }

    a1 := area(circle)
    if a1 < 12.5 or a1 > 12.7 { return false }  -- ~12.566

    a2 := area(rect)
    if a2 != 12.0 { return false }

    return true
}

-- ── Match without binding ─────────────────────────────────────────────────

describe :: proc(s: Shape) -> cstr {
    match s {
        case .Circle { return "circle" }
        case .Rect   { return "rect"   }
        else         { return "unknown" }
    }
}

check_no_binding :: proc() -> bool {
    circle := Shape{ tag = Shape_Tag.Circle, data = Shape_Data{ Circle = CircleData{ radius = 1.0 } } }
    rect   := Shape{ tag = Shape_Tag.Rect,   data = Shape_Data{ Rect   = RectData{ width = 1.0, height = 1.0 } } }

    if strcmp(describe(circle), "circle") != 0 { return false }
    if strcmp(describe(rect),   "rect")   != 0 { return false }
    return true
}

-- ── Tagged union as array element ─────────────────────────────────────────

check_array :: proc() -> bool {
    shapes: [3]Shape
    shapes[0] = Shape{ tag = Shape_Tag.Circle, data = Shape_Data{ Circle = CircleData{ radius = 1.0 } } }
    shapes[1] = Shape{ tag = Shape_Tag.Rect,   data = Shape_Data{ Rect   = RectData{ width = 2.0, height = 3.0 } } }
    shapes[2] = Shape{ tag = Shape_Tag.Circle, data = Shape_Data{ Circle = CircleData{ radius = 4.0 } } }

    total : f32 = 0.0
    for s in shapes {
        total += area(s)
    }
    -- circle(1): ~3.14, rect: 6.0, circle(4): ~50.26  → ~59.4
    if total < 59.0 or total > 60.0 { return false }

    return true
}

-- ── main ─────────────────────────────────────────────────────────────────

main :: proc() -> i32 {
    if not check_basic()      { printf("FAIL basic\n")      return 1 }
    if not check_no_binding() { printf("FAIL no_binding\n") return 1 }
    if not check_array()      { printf("FAIL array\n")      return 1 }

    printf("test_variant: OK\n\n\n")
    return 0
}
