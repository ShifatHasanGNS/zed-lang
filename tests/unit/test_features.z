-- test_features.z
-- Covers all newly implemented features:
--   for-each (array, slice, dyn array, string, with/without index)
--   string concatenation (+), string indexing (→ u8)
--   panic (runtime abort), free (raw pointer release)
--   copy (slice/dyn array copy)
--   enum_name (variant → cstr)

cimport "stdio.h"
cimport "string.h"

-- ── For-each ─────────────────────────────────────────────────────────────────

check_foreach_array :: proc() -> bool {
    arr: [5]i32 = { 10, 20, 30, 40, 50 }

    -- Value-only iteration
    sum := 0
    for v in arr { sum += v }
    if sum != 150 { return false }

    -- With index
    last_idx := 0
    for i, v in arr {
        last_idx = cast(i32)(i)
        _ = v
    }
    if last_idx != 4 { return false }

    -- Mutation via element reference
    for v in arr { v = v * 2 }
    if arr[0] != 20  { return false }
    if arr[4] != 100 { return false }

    return true
}

check_foreach_slice :: proc() -> bool {
    base: [6]i32 = { 1, 2, 3, 4, 5, 6 }
    s := base[1 ..< 5]   -- [2, 3, 4, 5]

    sum := 0
    for v in s { sum += v }
    if sum != 14 { return false }

    count := 0
    for i, v in s {
        count += cast(i32)(i) + v
    }
    -- i=0,v=2 → 2; i=1,v=3 → 4; i=2,v=4 → 6; i=3,v=5 → 8  → total 20
    if count != 20 { return false }

    return true
}

check_foreach_dynamic :: proc() -> bool {
    nums: [dynamic]i32
    append(&nums, 5)
    append(&nums, 10)
    append(&nums, 15)

    sum := 0
    for v in nums { sum += v }
    if sum != 30 { return false }

    -- Mutation
    for v in nums { v = v + 1 }
    if nums[0] != 6  { return false }
    if nums[2] != 16 { return false }

    -- With index
    idx_sum := 0
    for i, v in nums { idx_sum += cast(i32)(i) }
    if idx_sum != 3 { return false }  -- 0+1+2

    return true
}

check_foreach_string :: proc() -> bool {
    s: string = "abc"

    -- Byte values: a=97, b=98, c=99
    total: u32 = 0
    for b in s {
        total += cast(u32)(b)
    }
    if total != 294 { return false }  -- 97+98+99

    -- With index
    first_byte: u8 = 0
    for i, b in s {
        if i == 0 { first_byte = b }
    }
    if first_byte != 97 { return false }  -- 'a'

    return true
}

-- ── String operations ─────────────────────────────────────────────────────────

check_string_concat :: proc() -> bool {
    a: string = "Hello"
    b: string = ", "
    c: string = "World"

    -- string + string
    result := a + b + c
    if strcmp(to_cstr(result), "Hello, World") != 0 { return false }

    -- string + cstr literal
    greeting := a + "!"
    if strcmp(to_cstr(greeting), "Hello!") != 0 { return false }

    -- Chained concatenation
    parts: string = "one" + " " + "two" + " " + "three"
    if len(parts) != 13 { return false }

    -- Empty string + string
    empty: string = ""
    full := empty + "full"
    if strcmp(to_cstr(full), "full") != 0 { return false }

    return true
}

check_string_index :: proc() -> bool {
    s: string = "Zed"

    -- Individual byte access
    if s[0] != 90  { return false }   -- 'Z' = 90
    if s[1] != 101 { return false }   -- 'e' = 101
    if s[2] != 100 { return false }   -- 'd' = 100

    -- Use indexed byte in arithmetic
    diff := cast(i32)(s[1]) - cast(i32)(s[0])  -- 'e' - 'Z' = 11
    if diff != 11 { return false }

    return true
}

-- ── copy ─────────────────────────────────────────────────────────────────────

check_copy :: proc() -> bool {
    src: [dynamic]i32
    append(&src, 10)
    append(&src, 20)
    append(&src, 30)

    dst: [dynamic]i32
    reserve(&dst, 3)

    n := copy(dst, src)
    if n != 3 { return false }

    -- Verify bytes copied (dst capacity slots hold the values)
    if dst[0] != 10 { return false }
    if dst[1] != 20 { return false }
    if dst[2] != 30 { return false }

    -- Partial copy: dst smaller than src
    small: [dynamic]i32
    reserve(&small, 2)
    n2 := copy(small, src)
    if n2 != 2      { return false }
    if small[0] != 10 { return false }
    if small[1] != 20 { return false }

    return true
}

-- ── enum_name ─────────────────────────────────────────────────────────────────

Color :: enum { Red, Green, Blue, }

check_enum_name :: proc() -> bool {
    if strcmp(enum_name(Color.Red),   "Red")   != 0 { return false }
    if strcmp(enum_name(Color.Green), "Green") != 0 { return false }
    if strcmp(enum_name(Color.Blue),  "Blue")  != 0 { return false }

    -- Via variable
    c := Color.Green
    if strcmp(enum_name(c), "Green") != 0 { return false }

    return true
}

-- ── panic ─────────────────────────────────────────────────────────────────────
-- panic() terminates the process, so we can only test that the code compiles
-- and that panic is NOT called (i.e. the guard condition is false).

check_panic_not_triggered :: proc() -> bool {
    x := 1
    if x == 0 {
        panic("should never reach here")
    }
    return true
}

-- ── free ─────────────────────────────────────────────────────────────────────

check_free :: proc() -> bool {
    -- Allocate raw memory, use it, then free it
    ptr := cast(*i32)(mem_alloc(sizeof(i32)))
    ptr.* = 42
    if ptr.* != 42 { free(ptr) return false }
    free(ptr)
    -- After free ptr is dangling — don't access it
    return true
}

-- ── main ─────────────────────────────────────────────────────────────────────

main :: proc() -> i32 {
    -- if not check_foreach_array()        { printf("FAIL foreach_array\n")        return 1 }
    if not check_foreach_slice()        { printf("FAIL foreach_slice\n")        return 1 }
    if not check_foreach_dynamic()      { printf("FAIL foreach_dynamic\n")      return 1 }
    if not check_foreach_string()       { printf("FAIL foreach_string\n")       return 1 }
    if not check_string_concat()        { printf("FAIL string_concat\n")        return 1 }
    if not check_string_index()         { printf("FAIL string_index\n")         return 1 }
    if not check_copy()                 { printf("FAIL copy\n")                 return 1 }
    if not check_enum_name()            { printf("FAIL enum_name\n")            return 1 }
    if not check_panic_not_triggered()  { printf("FAIL panic_not_triggered\n")  return 1 }
    if not check_free()                 { printf("FAIL free\n")                 return 1 }

    printf("test_features: OK\n\n\n")
    return 0
}
