cimport "raylib.h"
cimport "math.h"

-- ═══════════════════════════════════════════════════════════════════════════
-- Constants
-- ═══════════════════════════════════════════════════════════════════════════

WINDOW_WIDTH  :: 1280
WINDOW_HEIGHT :: 720
TARGET_FPS    :: 60

ORBIT_SPEED   :: 0.005
PAN_SPEED     :: 0.003
ZOOM_SPEED    :: 0.15
MIN_DIST      :: 0.3
MAX_DIST      :: 50.0

-- ═══════════════════════════════════════════════════════════════════════════
-- OrbitCamera
-- ═══════════════════════════════════════════════════════════════════════════

OrbitCamera :: struct {
    target   : Vector3,
    azimuth  : f32,
    elevation: f32,
    distance : f32
}

orbit_to_camera3d :: proc(oc: OrbitCamera) -> Camera3D {
    cos_el := cosf(oc.elevation)
    eye    := Vector3{
        x = oc.target.x + oc.distance * cos_el * sinf(oc.azimuth),
        y = oc.target.y + oc.distance * sinf(oc.elevation),
        z = oc.target.z + oc.distance * cos_el * cosf(oc.azimuth)
    }
    cam            := Camera3D{}
    cam.position   = eye
    cam.target     = oc.target
    cam.up         = Vector3{ x = 0.0, y = 1.0, z = 0.0 }
    cam.fovy       = 45.0
    cam.projection = CAMERA_PERSPECTIVE
    return cam
}

-- ═══════════════════════════════════════════════════════════════════════════
-- main
-- ═══════════════════════════════════════════════════════════════════════════

main :: proc() -> i32 {
    SetConfigFlags(FLAG_VSYNC_HINT | FLAG_MSAA_4X_HINT)
    InitWindow(WINDOW_WIDTH, WINDOW_HEIGHT, "Model Viewer")
    defer CloseWindow()
    SetTargetFPS(TARGET_FPS)

    -- GLB is self-contained: meshes + materials + textures in one file.
    -- No material workarounds needed.
    -- model := LoadModel("tests/model_viewer/Assets/bunny.glb")
    model := LoadModel("tests/model_viewer/Assets/kminds-opti-base.glb")
    defer UnloadModel(model)

    -- Auto-fit
    bbox   := GetModelBoundingBox(model)
    size_x := bbox.max.x - bbox.min.x
    size_y := bbox.max.y - bbox.min.y
    size_z := bbox.max.z - bbox.min.z

    max_extent := max(size_x, max(size_y, size_z))
    model_scale : f32 = 1.0
    if max_extent > 0.0001 { model_scale = 2.0 / max_extent }

    model_pos := Vector3{
        x = -(bbox.min.x + size_x * 0.5) * model_scale,
        y = -(bbox.min.y + size_y * 0.5) * model_scale,
        z = -(bbox.min.z + size_z * 0.5) * model_scale
    }
    model_scale_v := Vector3{ x = model_scale, y = model_scale, z = model_scale }
    axis          := Vector3{ x = 0.0, y = 1.0, z = 0.0 }

    oc := OrbitCamera{
        target    = Vector3{ x = 0.0, y = 0.0, z = 0.0 },
        azimuth   = 0.785,
        elevation = 0.4,
        distance  = 5.0
    }

    draw_mode := 0   -- 0=solid, 1=solid+wireframe, 2=wireframe only

    prev_mouse := GetMousePosition()

    for not WindowShouldClose() {
        mouse      := GetMousePosition()
        dx         := mouse.x - prev_mouse.x
        dy         := mouse.y - prev_mouse.y
        prev_mouse  = mouse

        -- Orbit
        if IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
            oc.azimuth   -= dx * cast(f32)(ORBIT_SPEED)
            oc.elevation += dy * cast(f32)(ORBIT_SPEED)
            if oc.elevation >  1.55 { oc.elevation =  1.55 }
            if oc.elevation < -1.55 { oc.elevation = -1.55 }
        }

        -- Pan
        if IsMouseButtonDown(MOUSE_BUTTON_RIGHT) or IsMouseButtonDown(MOUSE_BUTTON_MIDDLE) {
            cos_az := cosf(oc.azimuth)
            sin_az := sinf(oc.azimuth)
            cos_el := cosf(oc.elevation)
            sin_el := sinf(oc.elevation)
            right  := Vector3{ x =  cos_az,          y = 0.0,    z = -sin_az }
            up     := Vector3{ x = -sin_el * sin_az,  y = cos_el, z = -sin_el * cos_az }
            pan    := cast(f32)(PAN_SPEED) * oc.distance
            oc.target.x -= (dx * right.x - dy * up.x) * pan
            oc.target.y -= (dx * right.y - dy * up.y) * pan
            oc.target.z -= (dx * right.z - dy * up.z) * pan
        }

        -- Zoom
        scroll := GetMouseWheelMove()
        if scroll != 0.0 {
            oc.distance *= 1.0 - scroll * cast(f32)(ZOOM_SPEED)
            if oc.distance < cast(f32)(MIN_DIST) { oc.distance = cast(f32)(MIN_DIST) }
            if oc.distance > cast(f32)(MAX_DIST) { oc.distance = cast(f32)(MAX_DIST) }
        }

        -- Reset view
        if IsKeyPressed(KEY_R) {
            oc.target    = Vector3{ x = 0.0, y = 0.0, z = 0.0 }
            oc.azimuth   = 0.785
            oc.elevation = 0.4
            oc.distance  = 5.0
        }

        -- Cycle draw mode
        if IsKeyPressed(KEY_M) {
            draw_mode = (draw_mode + 1) % 3
        }

        cam := orbit_to_camera3d(oc)

        BeginDrawing()
        ClearBackground(Color{ r = 25, g = 25, b = 25, a = 255 })

        BeginMode3D(cam)

        if draw_mode == 0 {
            DrawModelEx(model, model_pos, axis, 0.0, model_scale_v, WHITE)
        } else if draw_mode == 1 {
            DrawModelEx(model, model_pos, axis, 0.0, model_scale_v, WHITE)
            DrawModelWiresEx(model, model_pos, axis, 0.0, model_scale_v,
                Color{ r = 0, g = 200, b = 255, a = 120 })
        } else {
            DrawModelWiresEx(model, model_pos, axis, 0.0, model_scale_v, SKYBLUE)
        }

        DrawGrid(20, 0.5)
        DrawLine3D(Vector3{ x = -10.0, y = 0.0, z = 0.0 }, Vector3{ x = 10.0, y = 0.0, z = 0.0 }, RED)
        DrawLine3D(Vector3{ x = 0.0, y = -10.0, z = 0.0 }, Vector3{ x = 0.0, y = 10.0, z = 0.0 }, GREEN)
        DrawLine3D(Vector3{ x = 0.0, y = 0.0, z = -10.0 }, Vector3{ x = 0.0, y = 0.0, z = 10.0 }, BLUE)

        EndMode3D()

        DrawFPS(12, 12)
        DrawRectangle(10, WINDOW_HEIGHT - 130, 260, 120, Color{ r = 0, g = 0, b = 0, a = 140 })
        DrawText("LMB drag        Orbit",  18, WINDOW_HEIGHT - 124, 16, LIGHTGRAY)
        DrawText("RMB / MMB drag  Pan",    18, WINDOW_HEIGHT - 102, 16, LIGHTGRAY)
        DrawText("Scroll / Pinch  Zoom",   18, WINDOW_HEIGHT -  80, 16, LIGHTGRAY)
        DrawText("R               Reset",  18, WINDOW_HEIGHT -  58, 16, LIGHTGRAY)
        DrawText("M               Mode",   18, WINDOW_HEIGHT -  36, 16, LIGHTGRAY)

        EndDrawing()
    }

    return 0
}
